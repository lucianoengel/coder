{
  "models": {
    "gemini": {
      "model": "gemini-3-flash-preview",
      "apiEndpoint": "https://generativelanguage.googleapis.com/v1beta",
      "apiKeyEnv": "GEMINI_API_KEY"
    },
    "claude": {
      "model": "claude-sonnet-4-6",
      "apiEndpoint": "https://api.anthropic.com",
      "apiKeyEnv": "ANTHROPIC_API_KEY"
    },
    "codex": {
      "model": "gpt-5.3-codex",
      "apiEndpoint": "https://api.openai.com",
      "apiKeyEnv": "OPENAI_API_KEY"
    }
  },
  "sandbox": {
    "passEnv": [
      "GOOGLE_API_KEY",
      "GEMINI_API_KEY",
      "ANTHROPIC_API_KEY",
      "CLAUDE_CODE_OAUTH_TOKEN",
      "OPENAI_API_KEY",
      "GITHUB_TOKEN",
      "LINEAR_API_KEY"
    ],
    "passEnvPatterns": []
  },
  "workflow": {
    "agentRoles": {
      "issueSelector": "gemini",
      "planner": "claude",
      "planReviewer": "gemini",
      "programmer": "claude",
      "reviewer": "codex",
      "committer": "gemini",
      "coalesce": "codex"
    },
    "wip": {
      "push": true,
      "autoCommit": true,
      "includeUntracked": true,
      "remote": "origin",
      "failOnError": false
    },
    "scratchpad": {
      "sqliteSync": true,
      "sqlitePath": ".coder/state.db"
    },
    "issueSource": "github",
    "localIssuesDir": "",
    "maxPlanRevisions": 3,
    "hooks": [],
    "timeouts": {
      "issueSelection": 600000,
      "issueDraft": 600000,
      "planning": 2400000,
      "planReview": 2400000,
      "implementation": 3600000,
      "reviewRound": 1800000,
      "programmerFix": 2700000,
      "committerEscalation": 3600000,
      "finalGate": 5400000,
      "researchStep": 600000,
      "webSearch": 900000,
      "pocValidation": 720000,
      "designStep": 600000
    }
  },
  "agents": {
    "retry": {
      "retries": 1,
      "backoffMs": 5000,
      "retryOnRateLimit": true,
      "hangTimeoutMs": 300000
    },
    "fallback": {}
  },
  "ppcommit": {
    "preset": "strict",
    "enableLlm": true,
    "llmModelRef": "gemini"
  },
  "test": {
    "command": "",
    "allowNoTests": false,
    "setup": [],
    "teardown": [],
    "healthCheck": null,
    "timeoutMs": 600000
  },
  "design": {
    "stitch": {
      "enabled": false,
      "transport": "stdio",
      "serverCommand": "",
      "serverUrl": "",
      "apiKeyEnv": "GOOGLE_STITCH_API_KEY",
      "authHeader": "X-Goog-Api-Key"
    },
    "specDir": "spec/UI"
  },
  "github": {
    "useProjects": false,
    "epicAsMilestone": true,
    "defaultLabels": []
  }
}
